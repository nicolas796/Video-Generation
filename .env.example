# ============================================
# Product Video Generator - Environment Config
# ============================================

# ============================================
# FLASK CONFIGURATION
# ============================================

# Environment: development | production | testing
FLASK_ENV=development

# Debug mode: True for development, False for production
FLASK_DEBUG=True

# Secret key for sessions and CSRF protection
# IMPORTANT: Generate a strong random key for production!
# Use: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-random-key-here-change-in-production

# ============================================
# DATABASE CONFIGURATION
# ============================================

# Local Development: SQLite (default)
DATABASE_URL=sqlite:///app.db

# Render.com Production: PostgreSQL (auto-provided by Render)
# Render sets this automatically - DO NOT set manually on Render
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ============================================
# API KEYS (REQUIRED)
# ============================================

# Pollo.ai API Key - for video generation
# Get from: https://pollo.ai/
POLLO_API_KEY=your_pollo_api_key_here

# ElevenLabs API Key - for voiceover generation
# Get from: https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# OpenAI API Key - for script generation
# Get from: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# WEBHOOK CONFIGURATION (Required for Production)
# ============================================

# Secret for verifying Pollo.ai webhooks
# Generate a strong random string
POLLO_WEBHOOK_SECRET=your_webhook_secret_here

# Base URL for the application
# Local: http://localhost:5000
# Render: https://your-app-name.onrender.com
APP_BASE_URL=http://localhost:5000

# ============================================
# ELEVENLABS VOICE CONFIGURATION
# ============================================

# Default voice ID for voiceovers
# Find voice IDs at: https://elevenlabs.io/voice-library
DEFAULT_VOICE_ID=XB0fDUnXU5powFXDhCwa

# ============================================
# ADMIN USER (Initial Setup)
# ============================================

# Default admin credentials for first run
# Change these after initial login!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_admin_password

# ============================================
# UPLOAD CONFIGURATION
# ============================================

# Path for file uploads (relative or absolute)
# Default: ./uploads
UPLOAD_FOLDER=./uploads

# ============================================
# RENDER.COM DEPLOYMENT NOTES
# ============================================
#
# 1. Create a new Web Service on Render.com
# 2. Connect your GitHub repository
# 3. Render will auto-detect render.yaml and configure the service
# 4. Add the following Environment Variables in Render Dashboard:
#
#    REQUIRED SECRETS:
#    - SECRET_KEY: Generate with: python -c "import secrets; print(secrets.token_hex(32))"
#    - POLLO_API_KEY: Your Pollo.ai API key
#    - ELEVENLABS_API_KEY: Your ElevenLabs API key
#    - OPENAI_API_KEY: Your OpenAI API key
#    - POLLO_WEBHOOK_SECRET: Random secret for webhooks
#    - ADMIN_PASSWORD: Secure password for admin user
#
#    OPTIONAL:
#    - DEFAULT_VOICE_ID: Your preferred ElevenLabs voice
#
# 5. Render automatically provides:
#    - DATABASE_URL (PostgreSQL)
#    - FLASK_ENV=production
#    - APP_BASE_URL (your service URL)
#
# 6. Deploy! The build script will run migrations automatically.
#
# ============================================
